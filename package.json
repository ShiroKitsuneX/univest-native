    "@typescript-eslint/parser": "^8.59.0",
    "babel-plugin-module-resolver": "^5.0.3",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react": "^7.37.5",
    "jest": "~29.7.0",
    "jest-expo": "^55.0.16",
    "patch-package": "^8.0.1",
