    "@react-navigation/native": "^7.2.2",
    "@react-navigation/native-stack": "^7.14.11",
    "buffer": "^6.0.3",
    "expo": "^55.0.18",
    "expo-image-picker": "~55.0.19",
    "expo-status-bar": "~55.0.5",
    "firebase": "^12.12.0",
    "react": "19.2.0",
    "react-native": "0.83.6",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.30.0",
