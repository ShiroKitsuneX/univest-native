rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Usuarios
    match /usuarios/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Universidades
    match /universidades/{uniId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Posts
    match /posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Post likes subcollection
    match /posts/{postId}/likes/{likeId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == likeId;
    }
    
    // Reports
    match /reports/{reportId} {
      allow read: if true;
      allow create: if request.auth != null;
    }
    
    // Geo reference catalogs
    match /countries/{countryId} { allow read: if true; }
    match /states/{stateId} { allow read: if true; }
    match /cities/{cityId} { allow read: if true; }
    
    // Reference catalogs
    match /cursos/{cursoId} { allow read: if true; }
    match /icones/{iconId} { allow read: if true; }
    
    // Stories
    match /universidades/{uniId}/stories/{storyId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Notifications - FIXED: proper top-level path
    match /notifications/{notificationId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
    
    // Exam reminders
    match /examReminders/{reminderId} {
      allow read, write: if request.auth != null;
    }
    
    // User exam subcollections
    match /usuarios/{userId}/exams/{examId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    match /usuarios/{userId}/notas/{notaId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
}